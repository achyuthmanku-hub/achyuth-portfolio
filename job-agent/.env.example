# Apify (LinkedIn + Indeed): https://console.apify.com/account/integrations
APIFY_TOKEN=

# LLM for ATS resume tailoring (set at least one — required for 85-90% match)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email digest (Gmail: use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=achyuthmanku@gmail.com
SMTP_PASS=
RECIPIENT_EMAIL=achyuthmanku@gmail.com

# ── Job filters ──────────────────────────────────────────────
JOB_LOCATION=United States
US_ONLY=true

# Posting window: prefer ≤5h; if none, apply to 5–24h jobs
POSTED_FRESH_HOURS=5
POSTED_MAX_HOURS=24

# Hard skips (always on unless set to false)
SKIP_NO_SPONSORSHIP=true
SKIP_US_CITIZEN_ONLY=true
SKIP_SECURITY_CLEARANCE=true
SKIP_LINKEDIN_EASY_APPLY=true

# Match thresholds
MIN_MATCH_SCORE=70          # min role match to include in search results
MIN_APPLY_SCORE=75          # min role match to attempt apply
MIN_RESUME_MATCH=85         # min ATS resume↔JD match after tailoring
TARGET_RESUME_MATCH_MIN=85
TARGET_RESUME_MATCH_MAX=90
TAILOR_MAX_PASSES=3

MAX_JOBS_PER_PLATFORM=20
LINKEDIN_POSTED_WINDOW=r86400

# Applicant details (also edit applicant-profile.json for portal-specific fields)
APPLICANT_FIRST_NAME=Achyuth
APPLICANT_LAST_NAME=Manku
APPLICANT_EMAIL=achyuthmanku@gmail.com
APPLICANT_PHONE=(513) 799-8391
APPLICANT_LINKEDIN=
APPLICANT_GITHUB=
APPLICANT_WEBSITE=

# Automation
AUTO_APPLY=false
AUTO_SUBMIT=false
HEADLESS=false
APPLY_LIMIT=5

# Google Sheets report (see GOOGLE_SHEETS_SETUP.md)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json
GOOGLE_SHEETS_APPLICATIONS_TAB=Applications
GOOGLE_SHEETS_SUMMARY_TAB=Daily Summary
