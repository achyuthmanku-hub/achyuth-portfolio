      "parameters": {
        "method": "POST",
        "url": "https://docs.googleapis.com/v1/documents",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDocsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": \"{{ $json.docTitle }}\"\n}",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000010",
      "name": "Create Google Doc",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1260, -120]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://docs.googleapis.com/v1/documents/{{ $json.documentId }}:batchUpdate",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDocsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"requests\": [\n    {\n      \"insertText\": {\n        \"location\": { \"index\": 1 },\n        \"text\": {{ JSON.stringify($('Merge Resume + Job Meta').item.json.tailoredResume) }}\n      }\n    }\n  ]\n}",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000011",
      "name": "Insert Resume Text",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1480, -120]
    },
    {
      "parameters": {
        "operation": "update",
        "fileId": {
          "__rl": true,
          "value": "={{ $('Create Google Doc').item.json.documentId }}",
          "mode": "id"
        },
        "parents": ["={{ $('Workflow Configuration').item.json.targetFolderId }}"],
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000012",
      "name": "Share Resume",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1700, -120]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "l1",
              "name": "jobLine",
              "value": "={{ $('Merge Resume + Job Meta').item.json.jobTitle }} @ {{ $('Merge Resume + Job Meta').item.json.companyName }}\n→ Job: {{ $('Merge Resume + Job Meta').item.json.jobUrl }}\n→ Tailored Resume: https://docs.google.com/document/d/{{ $('Create Google Doc').item.json.documentId }}/edit",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000013",
      "name": "Build Link Text",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1920, -120]
    },
    {
      "parameters": {
        "fieldsToAggregate": {
          "fieldToAggregate": [
            { "fieldToAggregate": "jobLine" }
          ]
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000014",
      "name": "Email Summary",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [2140, -120]
    },
    {
      "parameters": {
        "sendTo": "={{ $('Workflow Configuration').first().json.recipientEmail }}",
        "subject": "=Your {{ $('Workflow Configuration').first().json.maxJobs }} Tailored Resumes for {{ $now.format('yyyy-MM-dd') }}",
        "emailType": "text",
        "message": "=Good morning! Here are your AI-tailored resumes for today's freshest LinkedIn matches:\n\n{{ $json.jobLine.join('\\n\\n') }}\n\n— Your n8n Resume Bot",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000015",
      "name": "Send Message",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [2360, -120],
      "webhookId": "send-message"
    }
  ],
