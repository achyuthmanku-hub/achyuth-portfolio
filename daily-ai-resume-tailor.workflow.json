{
  "name": "Daily AI Resume Tailor",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "triggerAtHour": 7,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "1a000000-0000-0000-0000-000000000001",
      "name": "Daily 7AM Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-1600, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "c1", "name": "searchQuery", "value": "Software Engineer Java Spring Boot Generative AI", "type": "string" },
            { "id": "c2", "name": "location", "value": "United States", "type": "string" },
            { "id": "c3", "name": "datePosted", "value": "r86400", "type": "string" },
            { "id": "c4", "name": "resumeFileId", "value": "PUT_YOUR_GOOGLE_DOC_RESUME_ID_HERE", "type": "string" },
            { "id": "c5", "name": "targetFolderId", "value": "PUT_YOUR_TARGET_DRIVE_FOLDER_ID_HERE", "type": "string" },
            { "id": "c6", "name": "recipientEmail", "value": "achyuthmanku@gmail.com", "type": "string" },
            { "id": "c7", "name": "apifyActorId", "value": "bebity~linkedin-jobs-scraper", "type": "string" },
            { "id": "c8", "name": "maxJobs", "value": 15, "type": "number" }
          ]
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000002",
      "name": "Workflow Configuration",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1380, 0]
    },
    {
      "parameters": {
        "url": "=https://docs.googleapis.com/v1/documents/{{ $json.resumeFileId }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDocsOAuth2Api",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000003",
      "name": "Google Docs API - Get Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1160, 0]
    },
    {
      "parameters": {
        "jsCode": "const doc = $input.first().json;\nlet text = '';\nif (doc.body && doc.body.content) {\n  for (const element of doc.body.content) {\n    if (element.paragraph && element.paragraph.elements) {\n      for (const el of element.paragraph.elements) {\n        if (el.textRun && el.textRun.content) text += el.textRun.content;\n      }\n    }\n  }\n}\nreturn [{ json: { resumeText: text.trim() } }];"
      },
      "id": "1a000000-0000-0000-0000-000000000004",
      "name": "Extract File Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-940, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "u1",
              "name": "linkedinUrl",
              "value": "=https://www.linkedin.com/jobs/search/?keywords={{ encodeURIComponent($('Workflow Configuration').item.json.searchQuery) }}&location={{ encodeURIComponent($('Workflow Configuration').item.json.location) }}&f_TPR={{ $('Workflow Configuration').item.json.datePosted }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000005",
      "name": "Build LinkedIn URL",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-720, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.apify.com/v2/acts/{{ $('Workflow Configuration').item.json.apifyActorId }}/runs",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urls\": [{ \"url\": \"{{ $('Build LinkedIn URL').item.json.linkedinUrl }}\" }],\n  \"count\": 25,\n  \"scrapeCompany\": false\n}",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000006",
      "name": "Apify - Fetch Jobs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-500, 0]
    },
    {
      "parameters": {
        "url": "=https://api.apify.com/v2/actor-runs/{{ $('Apify - Fetch Jobs').item.json.data.id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000007",
      "name": "Check Apify Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-280, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "if1",
              "leftValue": "={{ $json.data.status }}",
              "rightValue": "SUCCEEDED",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-000000000008",
      "name": "Is Job Complete?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-60, 0]
    },
    {
      "parameters": {
        "amount": 15,
        "unit": "seconds"
      },
      "id": "1a000000-0000-0000-0000-000000000009",
      "name": "Wait 15 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [-60, 220],
      "webhookId": "wait-15s"
    },
    {
      "parameters": {
        "url": "=https://api.apify.com/v2/actor-runs/{{ $('Apify - Fetch Jobs').item.json.data.id }}/dataset/items",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-00000000000a",
      "name": "Fetch Apify Results",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [160, -120]
    },
    {
      "parameters": {
        "maxItems": "={{ $('Workflow Configuration').item.json.maxJobs }}"
      },
      "id": "1a000000-0000-0000-0000-00000000000b",
      "name": "Limit to 5 Jobs",
      "type": "n8n-nodes-base.limit",
      "typeVersion": 1,
      "position": [380, -120]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=ORIGINAL RESUME:\n{{ $('Extract File Text').item.json.resumeText }}\n\n--- JOB ---\nTITLE: {{ $json.title }}\nCOMPANY: {{ $json.companyName }}\nLOCATION: {{ $json.location }}\nDESCRIPTION:\n{{ ($json.description || '').slice(0, 6000) }}\n\nRewrite the resume above to perfectly match this job. Output only the rewritten resume in plain text.",
        "options": {
          "systemMessage": "You are an expert ATS resume optimizer. Rewrite the candidate's resume so it perfectly matches the provided job description, naturally weaving in exact keywords from the JD. Do NOT fabricate experience. Keep the same sections and roughly the same length as the original. Output ONLY the rewritten resume in clean plain text — no preamble, no markdown."
        }
      },
      "id": "1a000000-0000-0000-0000-00000000000c",
      "name": "ATS Optimizer Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [600, -120]
    },
    {
      "parameters": {
        "modelName": "models/gemini-2.0-flash",
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-00000000000d",
      "name": "Google Gemini Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [600, 80]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "m1", "name": "tailoredResume", "value": "={{ $json.output }}", "type": "string" },
            { "id": "m2", "name": "jobTitle", "value": "={{ $('Limit to 5 Jobs').item.json.title }}", "type": "string" },
            { "id": "m3", "name": "companyName", "value": "={{ $('Limit to 5 Jobs').item.json.companyName }}", "type": "string" },
            { "id": "m4", "name": "jobUrl", "value": "={{ $('Limit to 5 Jobs').item.json.link || $('Limit to 5 Jobs').item.json.jobUrl }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-00000000000e",
      "name": "Merge Resume + Job Meta",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [820, -120]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "d1",
              "name": "docTitle",
              "value": "=Resume - {{ $json.companyName }} - {{ $json.jobTitle }} - {{ $now.format('yyyy-MM-dd') }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "1a000000-0000-0000-0000-00000000000f",
      "name": "Make Doc Metadata",
      "type": "n8n-nodes-base.set",
